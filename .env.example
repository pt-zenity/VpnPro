# =============================================================================
# Environment configuration for OVPN Admin Panel v1.2.0
# Copy to `.env` and replace EVERY value below.
#
# The application REFUSES to start in production with missing or default
# secrets — generate strong values with:
#   openssl rand -base64 48   (for JWT_SECRET, API_TOKEN_SALT)
#   openssl rand -hex 32      (for ENCRYPTION_KEY — must be exactly 32 bytes)
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Native install:  postgresql://ovpn:<password>@localhost:5432/ovpn_admin
# Docker compose:  postgresql://ovpn:${POSTGRES_PASSWORD}@postgres:5432/ovpn_admin
DATABASE_URL="postgresql://ovpn:CHANGE_ME@localhost:5432/ovpn_admin"

# Used by docker/compose.yml only — sets the postgres container root password
# and is interpolated into the DATABASE_URL the compose file builds.
POSTGRES_PASSWORD="CHANGE_ME"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for login rate limiting.
# No-password (local dev / native install): redis://localhost:6379
# With password (recommended in production): redis://:PASSWORD@localhost:6379
# Docker compose: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ── Security (REQUIRED — no defaults accepted in production) ──────────────────
# Generate each value independently:
#   JWT_SECRET:       openssl rand -base64 48    (min 32 chars)
#   ENCRYPTION_KEY:   openssl rand -hex 32       (exactly 32 hex bytes = 256-bit AES key)
#   API_TOKEN_SALT:   openssl rand -base64 32    (min 16 chars)
JWT_SECRET="REPLACE_WITH_openssl_rand_base64_48"
ENCRYPTION_KEY="REPLACE_WITH_openssl_rand_hex_32"
API_TOKEN_SALT="REPLACE_WITH_openssl_rand_base64_32"

# ── Application URLs ──────────────────────────────────────────────────────────
# Used to build agent install commands in the UI — MUST be HTTPS in production.
# Both values should be identical and point to your panel's public URL.
NEXT_PUBLIC_APP_URL="https://panel.example.com"
PANEL_URL="https://panel.example.com"

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV="development"

# ── Initial Admin Seed ────────────────────────────────────────────────────────
# Used by `pnpm db:seed` to create the first ADMIN account.
# REQUIRED in production before first startup.
# After seeding, delete or rotate SEED_ADMIN_PASSWORD for security.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# ── Agent Configuration ───────────────────────────────────────────────────────
# Heartbeat interval (seconds) — how often the agent polls the panel.
AGENT_HEARTBEAT_INTERVAL="30"
# Heartbeat request timeout (seconds).
AGENT_HEARTBEAT_TIMEOUT="5"
